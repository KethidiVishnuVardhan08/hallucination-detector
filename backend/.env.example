# Copy this file to .env and fill in your keys.
# You only need ONE provider's key depending on LLM_PROVIDER below.

# "anthropic", "openai", or "groq" — which model is being TESTED for hallucination.
LLM_PROVIDER=groq

# --- Groq (default) ---
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant
# Other fast Groq models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it

# --- Anthropic (alternative) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# --- OpenAI (alternative) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Self-consistency sampling
N_SAMPLES=6
SAMPLING_TEMPERATURE=0.9
MAX_TOKENS_PER_SAMPLE=220

# "sentence-transformers" (better, needs one-time model download) or "tfidf" (offline, lower quality)
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Score combination weights (entropy term available for groq and openai providers)
WEIGHT_DIVERGENCE=0.75
WEIGHT_ENTROPY=0.25

# Decision threshold — re-tune this after running evaluation/evaluate.py
RISK_THRESHOLD=0.45
